  "components": {
    "schemas": {
      "BatchVerificationResult": {
        "properties": {
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "verified": {
            "type": "integer",
            "title": "Verified"
          },
          "failed": {
            "type": "integer",
            "title": "Failed"
          },
          "results": {
            "items": {},
            "type": "array",
            "title": "Results"
          }
        },
        "type": "object",
        "required": [
          "total",
          "verified",
          "failed",
          "results"
        ],
        "title": "BatchVerificationResult"
      },
      "GraphQueryRequest": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query"
          },
          "include_evidence": {
            "type": "boolean",
            "title": "Include Evidence",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "GraphQueryRequest"
      },
      "GraphQueryResponse": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query"
          },
          "domain": {
            "type": "string",
            "title": "Domain"
          },
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "evidence_chain": {
            "items": {},
            "type": "array",
            "title": "Evidence Chain"
          },
          "processing_time_ms": {
            "type": "integer",
            "title": "Processing Time Ms"
          }
        },
        "type": "object",
        "required": [
          "query",
          "domain",
          "answer",
          "evidence_chain",
          "processing_time_ms"
        ],
        "title": "GraphQueryResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "QueryRequest": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query"
          },
          "location": {
            "type": "string",
            "title": "Location",
            "default": "Mumbai, India"
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "QueryRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "VerificationResult": {
        "properties": {
          "prediction_id": {
            "type": "string",
            "title": "Prediction Id"
          },
          "asteroid_id": {
            "type": "string",
            "title": "Asteroid Id"
          },
          "verification_hash": {
            "type": "string",
            "title": "Verification Hash"
          },
          "hash_valid": {
            "type": "boolean",
            "title": "Hash Valid"
          },
          "risk_category": {
            "type": "string",
            "title": "Risk Category"
          },
          "anomaly_score": {
            "type": "number",
            "title": "Anomaly Score"
          },
          "is_anomaly": {
            "type": "boolean",
            "title": "Is Anomaly"
          },
          "cluster": {
            "type": "integer",
            "title": "Cluster"
          },
          "improved_risk_score": {
            "type": "number",
